          "expr": "sum by (path_bucket) (count_over_time({container=~\".*anubis.*\", request_host=~\"$host\"} | request_path != `` | label_format path_bucket=`{{ if hasPrefix \"/api/v2/ingredient\" .request_path }}ingredient api{{ else if hasPrefix \"/api/v2/exercise\" .request_path }}exercise api{{ else if eq (regexReplaceAll \"^/[a-z]{2}(-[a-z]+)?/nutrition/ingredient/.*\" .request_path \"MATCH\") \"MATCH\" }}ingredient detail{{ else if eq (regexReplaceAll \"^/[a-z]{2}(-[a-z]+)?/exercise/.*\" .request_path \"MATCH\") \"MATCH\" }}exercise detail{{ else }}others{{ end }}` [$__range]))",
